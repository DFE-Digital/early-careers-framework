{
  "$id": "https://digital.education.gov.uk/schema/types.json/#",
  "$schema": "http://json-schema.org/draft-04/schema#",
  "definitions": {
    "uuid": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "ecf_declaration_type": {
      "enum": [
        "started",
        "retained-1",
        "retained-2",
        "retained-3",
        "retained-4",
        "completed"
      ]
    },
    "declaration_date": {
      "type": "string",
      "format": "date-time"
    },
    "npq_declaration_type": {
      "enum": [
        "accepted",
        "rejected",
        "started",
        "retained-1",
        "retained-2",
        "retained-3",
        "retained-4",
        "completed"
      ]
    }
  }
}
