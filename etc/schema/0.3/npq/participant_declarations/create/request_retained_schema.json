{
  "$id": "https://digital.education.gov.uk/schema/ecf/participant_declarations/create/request_retained_schema.json",
  "$schema": "http://json-schema.org/draft-04/schema#",
  "type": "object",
  "properties": {
    "course_type": {
      "enum": [
        "npq-leading-teaching",
        "npq-leading-teaching-development",
        "npq-leading-behaviour-culture",
        "npq-headship",
        "npq-senior-leadership",
        "npq-executive-leadership"
      ]
    },
    "declaration_type": {
      "enum": [
        "retained-1",
        "retained-2",
        "retained-3",
        "retained-4"
      ]
    },
    "evidence_held": {
      "enum": [
        "training-event-attended",
        "self-study-material-completed"
      ]
    },
    "declaration_date": {
      "type": "string",
      "format": "date-time"
    },
    "participant_id": {
      "type": "string"
    }
  },
  "required": [
    "course_type",
    "declaration_type",
    "declaration_date",
    "participant_id",
    "evidence_held"
  ],
  "additionalProperties": false
}
