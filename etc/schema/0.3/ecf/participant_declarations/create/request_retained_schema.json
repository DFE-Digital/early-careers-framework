{
  "$id": "https://digital.education.gov.uk/schema/ecf/participant_declarations/create/request_retained_schema.json",
  "$schema": "http://json-schema.org/draft-04/schema#",
  "type": "object",
  "properties": {
    "declaration_date": {
      "type": "string",
      "format": "date-time"
    },
    "declaration_type": {
      "enum": [
        "retained-1",
        "retained-2",
        "retained-3",
        "retained-4"
      ]
    },
    "evidence_held": {
      "enum": [
        "training-event-attended",
        "self-study-material-completed"
      ]
    },
    "participant_id": {
      "type": "string"
    },
    "course_type": {
      "enum": [
        "ecf-induction",
        "ecf-mentor"
      ]
    }
  },
  "additionalProperties": false,
  "required": [
    "declaration_date",
    "declaration_type",
    "participant_id",
    "course_type",
    "evidence_held"
  ]
}
