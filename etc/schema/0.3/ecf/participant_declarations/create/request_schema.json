{
  "$id": "https://digital.education.gov.uk/schema/ecf/participant_declarations/create/request_schema.json",
  "$schema": "http://json-schema.org/draft-04/schema#",
  "type": "object",
  "properties": {
    "data": {
      "type": "object",
      "properties": {
        "type": {
          "enum": ["participant_declaration"]
        },
        "attributes": {
          "programme_type": {
            "enum": [
              "ecf-early-career-teacher",
              "ecf-mentor"
            ]
          },
          "oneOf": [
            {
              "declaration_type": {
                "enum": [
                  "started",
                  "completed"
                ]
              }
            },
            {
              "declaration_type": {
                "enum": [
                  "retained-1",
                  "retained-2",
                  "retained-3",
                  "retained-4"
                ]
              },
              "evidence_held": {
                "enum": [
                  "training-event-attended",
                  "self-study-material-completed"
                ]
              }
            }
          ],
          "declaration_date": {
            "type": "string",
            "format": "date-time"
          },
          "participant_id": {
            "type": "string"
          },
          "required": [
            "programme_type",
            "declaration_type",
            "declaration_date",
            "participant_id"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "type",
        "attributes"
      ],
      "additionalProperties": false
    }
  },
  "required": ["data"],
  "additionalProperties": false
}
